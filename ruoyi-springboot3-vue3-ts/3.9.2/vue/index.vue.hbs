---
basePath: "vue/views/{{module_name}}/{{model_camel}}"
filename: "index.vue"
---
<template>
  <div class="app-container">
    <el-form :model="queryParams" ref="queryRef" :inline="true" v-show="showSearch" label-width="68px">
{{#each fields}}
{{#if query}}
{{#if is_input}}
      <el-form-item label="{{comment}}" prop="{{name_camel}}">
        <el-input
          v-model="queryParams.{{name_camel}}"
          placeholder="请输入{{comment}}"
          clearable
          @keyup.enter="handleQuery"
        />
      </el-form-item>
{{/if}}
{{#if is_select}}
      <el-form-item label="{{comment}}" prop="{{name_camel}}">
        <el-select v-model="queryParams.{{name_camel}}" placeholder="请选择{{comment}}" clearable>
          {{#if dict_type}}
          <el-option
            v-for="dict in {{dict_type}}"
            :key="dict.value"
            :label="dict.label"
            :value="dict.value"
          />
          {{else}}
          <el-option label="请选择字典生成" value="" />
          {{/if}}
        </el-select>
      </el-form-item>
{{/if}}
{{#if is_radio}}
      <el-form-item label="{{comment}}" prop="{{name_camel}}">
        <el-select v-model="queryParams.{{name_camel}}" placeholder="请选择{{comment}}" clearable>
          {{#if dict_type}}
          <el-option
            v-for="dict in {{dict_type}}"
            :key="dict.value"
            :label="dict.label"
            :value="dict.value"
          />
          {{else}}
          <el-option label="请选择字典生成" value="" />
          {{/if}}
        </el-select>
      </el-form-item>
{{/if}}
{{#if is_datetime}}
{{#unless query_between}}
      <el-form-item label="{{comment}}" prop="{{name_camel}}">
        <el-date-picker clearable
          v-model="queryParams.{{name_camel}}"
          type="date"
          value-format="YYYY-MM-DD"
          placeholder="请选择{{comment}}"
        />
      </el-form-item>
{{/unless}}
{{#if query_between}}
      <el-form-item label="{{comment}}" style="width: 308px">
        <el-date-picker
          v-model="daterange{{name_pascal}}"
          value-format="YYYY-MM-DD"
          type="daterange"
          range-separator="-"
          start-placeholder="开始日期"
          end-placeholder="结束日期"
        />
      </el-form-item>
{{/if}}
{{/if}}
{{/if}}
{{/each}}
      <el-form-item>
        <el-button type="primary" icon="Search" @click="handleQuery">搜索</el-button>
        <el-button icon="Refresh" @click="resetQuery">重置</el-button>
      </el-form-item>
    </el-form>

    <el-row :gutter="10" class="mb8">
      <el-col :span="1.5">
        <el-button type="primary" plain icon="Plus" @click="handleAdd" v-hasPermi="['{{permission_prefix}}:add']">新增</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button type="success" plain icon="Edit" :disabled="single" @click="handleUpdate" v-hasPermi="['{{permission_prefix}}:edit']">修改</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button type="danger" plain icon="Delete" :disabled="multiple" @click="handleDelete" v-hasPermi="['{{permission_prefix}}:remove']">删除</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button type="warning" plain icon="Download" @click="handleExport" v-hasPermi="['{{permission_prefix}}:export']">导出</el-button>
      </el-col>
      <right-toolbar v-model:showSearch="showSearch" @queryTable="getList" />
    </el-row>

    <el-table v-loading="loading" :data="{{model_camel}}List" @selection-change="handleSelectionChange">
      <el-table-column type="selection" width="55" align="center" />
{{#each fields}}
{{#if is_pk}}
      <el-table-column label="{{comment}}" align="center" prop="{{name_camel}}" />
{{/if}}
{{#unless is_pk}}
{{#if list}}
{{#if is_datetime}}
      <el-table-column label="{{comment}}" align="center" prop="{{name_camel}}" width="180">
        <template #default="scope">
          <span>{{ parseTime(scope.row.{{name_camel}}, '{y}-{m}-{d}') }}</span>
        </template>
      </el-table-column>
{{/if}}
{{#if is_image}}
      <el-table-column label="{{comment}}" align="center" prop="{{name_camel}}" width="100">
        <template #default="scope">
          <image-preview :src="scope.row.{{name_camel}}" :width="50" :height="50" />
        </template>
      </el-table-column>
{{/if}}
{{#unless is_datetime}}
{{#unless is_image}}
{{#if dict_type}}
      <el-table-column label="{{comment}}" align="center" prop="{{name_camel}}">
        <template #default="scope">
{{#if is_checkbox}}
          <dict-tag :options="{{dict_type}}" :value="scope.row.{{name_camel}} ? scope.row.{{name_camel}}.split(',') : []" />
{{else}}
          <dict-tag :options="{{dict_type}}" :value="scope.row.{{name_camel}}" />
{{/if}}
        </template>
      </el-table-column>
{{else}}
      <el-table-column label="{{comment}}" align="center" prop="{{name_camel}}" />
{{/if}}
{{/unless}}
{{/unless}}
{{/if}}
{{/unless}}
{{/each}}
      <el-table-column label="操作" align="center" class-name="small-padding fixed-width">
        <template #default="scope">
          <el-button link type="primary" icon="Edit" @click="handleUpdate(scope.row)" v-hasPermi="['{{permission_prefix}}:edit']">修改</el-button>
          <el-button link type="primary" icon="Delete" @click="handleDelete(scope.row)" v-hasPermi="['{{permission_prefix}}:remove']">删除</el-button>
        </template>
      </el-table-column>
    </el-table>

    <pagination
      v-show="total > 0"
      :total="total"
      v-model:page="queryParams.pageNum"
      v-model:limit="queryParams.pageSize"
      @pagination="getList"
    />

    <!-- 添加或修改{{function_name}}对话框 -->
    <el-dialog :title="title" v-model="open" width="500px" append-to-body>
      <el-form ref="{{model_camel}}Ref" :model="form" :rules="rules" label-width="80px">
{{#each fields}}
{{#if insert}}
{{#unless is_pk}}
{{#if is_input}}
        <el-form-item label="{{comment}}" prop="{{name_camel}}">
          <el-input v-model="form.{{name_camel}}" placeholder="请输入{{comment}}" />
        </el-form-item>
{{/if}}
{{#if is_textarea}}
        <el-form-item label="{{comment}}" prop="{{name_camel}}">
          <el-input v-model="form.{{name_camel}}" type="textarea" placeholder="请输入内容" />
        </el-form-item>
{{/if}}
{{#if is_image}}
        <el-form-item label="{{comment}}" prop="{{name_camel}}">
          <image-upload v-model="form.{{name_camel}}" />
        </el-form-item>
{{/if}}
{{#if is_file}}
        <el-form-item label="{{comment}}" prop="{{name_camel}}">
          <file-upload v-model="form.{{name_camel}}" />
        </el-form-item>
{{/if}}
{{#if is_editor}}
        <el-form-item label="{{comment}}">
          <editor v-model="form.{{name_camel}}" :min-height="192" />
        </el-form-item>
{{/if}}
{{#if is_select}}
        <el-form-item label="{{comment}}" prop="{{name_camel}}">
          <el-select v-model="form.{{name_camel}}" placeholder="请选择{{comment}}">
            {{#if dict_type}}
            <el-option
              v-for="dict in {{dict_type}}"
              :key="dict.value"
              :label="dict.label"
              :value="dict.value"
            />
            {{else}}
            <el-option label="请选择字典生成" value="" />
            {{/if}}
          </el-select>
        </el-form-item>
{{/if}}
{{#if is_radio}}
        <el-form-item label="{{comment}}" prop="{{name_camel}}">
          <el-radio-group v-model="form.{{name_camel}}">
            {{#if dict_type}}
            <el-radio v-for="dict in {{dict_type}}" :key="dict.value" :label="dict.value">{{dict.label}}</el-radio>
            {{else}}
            <el-radio label="1">请选择字典生成</el-radio>
            {{/if}}
          </el-radio-group>
        </el-form-item>
{{/if}}
{{#if is_checkbox}}
        <el-form-item label="{{comment}}" prop="{{name_camel}}">
          <el-checkbox-group v-model="form.{{name_camel}}">
            {{#if dict_type}}
            <el-checkbox v-for="dict in {{dict_type}}" :key="dict.value" :label="dict.value">{{dict.label}}</el-checkbox>
            {{else}}
            <el-checkbox>请选择字典生成</el-checkbox>
            {{/if}}
          </el-checkbox-group>
        </el-form-item>
{{/if}}
{{#if is_datetime}}
        <el-form-item label="{{comment}}" prop="{{name_camel}}">
          <el-date-picker clearable
            v-model="form.{{name_camel}}"
            type="date"
            value-format="YYYY-MM-DD"
            placeholder="请选择{{comment}}"
          />
        </el-form-item>
{{/if}}
{{/unless}}
{{/if}}
{{/each}}
      </el-form>
      <template #footer>
        <div class="dialog-footer">
          <el-button type="primary" @click="submitForm">确 定</el-button>
          <el-button @click="cancel">取 消</el-button>
        </div>
      </template>
    </el-dialog>
  </div>
</template>

<script setup lang="ts" name="{{model_pascal}}">
import type { {{model_pascal}}, {{model_pascal}}QueryParams } from '@/types/api/{{module_name}}/{{model_camel}}'
import { list{{model_pascal}}, get{{model_pascal}}, del{{model_pascal}}, add{{model_pascal}}, update{{model_pascal}} } from '@/api/{{module_name}}/{{model_camel}}'

const { proxy } = getCurrentInstance()!

const {{model_camel}}List = ref<{{model_pascal}}[]>([])
const open = ref<boolean>(false)
const loading = ref<boolean>(true)
const showSearch = ref<boolean>(true)
const ids = ref<number[]>([])
const single = ref<boolean>(true)
const multiple = ref<boolean>(true)
const total = ref<number>(0)
const title = ref<string>('')
{{#each fields}}
{{#if is_datetime}}
{{#if query_between}}
const daterange{{name_pascal}} = ref<string[]>([])
{{/if}}
{{/if}}
{{/each}}

const data = reactive({
  form: {} as {{model_pascal}},
  queryParams: {
    pageNum: 1,
    pageSize: 10,
{{#each fields}}
{{#if query}}
    {{name_camel}}: undefined,
{{/if}}
{{/each}}
  } as {{model_pascal}}QueryParams,
  rules: {
{{#each fields}}
{{#if required}}
{{#unless is_pk}}
{{#if is_select}}
    {{name_camel}}: [{ required: true, message: '{{comment}}不能为空', trigger: 'change' }],
{{else}}
{{#if is_radio}}
    {{name_camel}}: [{ required: true, message: '{{comment}}不能为空', trigger: 'change' }],
{{else}}
{{#if is_checkbox}}
    {{name_camel}}: [{ required: true, message: '{{comment}}不能为空', trigger: 'change' }],
{{else}}
    {{name_camel}}: [{ required: true, message: '{{comment}}不能为空', trigger: 'blur' }],
{{/if}}
{{/if}}
{{/if}}
{{/unless}}
{{/if}}
{{/each}}
  } as Record<string, any>
})

const { queryParams, form, rules } = toRefs(data)

function getList() {
  loading.value = true
{{#each fields}}
{{#if is_datetime}}
{{#if query_between}}
  queryParams.value.params = queryParams.value.params ?? {}
  if (daterange{{name_pascal}}.value?.length === 2) {
    queryParams.value.params['begin{{name_pascal}}'] = daterange{{name_pascal}}.value[0]
    queryParams.value.params['end{{name_pascal}}'] = daterange{{name_pascal}}.value[1]
  }
{{/if}}
{{/if}}
{{/each}}
  list{{model_pascal}}(queryParams.value).then(response => {
    {{model_camel}}List.value = response.rows
    total.value = response.total
    loading.value = false
  })
}

function cancel() {
  open.value = false
  reset()
}

function reset() {
  form.value = {} as {{model_pascal}}
  proxy!.resetForm('{{model_camel}}Ref')
}

function handleQuery() {
  queryParams.value.pageNum = 1
  getList()
}

function resetQuery() {
{{#each fields}}
{{#if is_datetime}}
{{#if query_between}}
  daterange{{name_pascal}}.value = []
{{/if}}
{{/if}}
{{/each}}
  proxy!.resetForm('queryRef')
  handleQuery()
}

function handleSelectionChange(selection: {{model_pascal}}[]) {
  ids.value = selection.map(item => item.{{pk_field}} as number)
  single.value = selection.length !== 1
  multiple.value = !selection.length
}

function handleAdd() {
  reset()
  open.value = true
  title.value = '添加{{function_name}}'
}

function handleUpdate(row: {{model_pascal}}) {
  reset()
  const _{{pk_field}} = row.{{pk_field}} ?? ids.value[0]
  get{{model_pascal}}(_{{pk_field}}).then(response => {
    form.value = response.data
{{#each fields}}
{{#if is_checkbox}}
    if (form.value.{{name_camel}}) {
      form.value.{{name_camel}} = (form.value.{{name_camel}} as unknown as string).split(',') as any
    }
{{/if}}
{{/each}}
    open.value = true
    title.value = '修改{{function_name}}'
  })
}

function submitForm() {
  proxy!.$refs['{{model_camel}}Ref'].validate((valid: boolean) => {
    if (valid) {
{{#each fields}}
{{#if is_checkbox}}
      if (Array.isArray(form.value.{{name_camel}})) {
        form.value.{{name_camel}} = (form.value.{{name_camel}} as unknown as string[]).join(',') as any
      }
{{/if}}
{{/each}}
      if (form.value.{{pk_field}} != null) {
        update{{model_pascal}}(form.value).then(() => {
          proxy!.$modal.msgSuccess('修改成功')
          open.value = false
          getList()
        })
      } else {
        add{{model_pascal}}(form.value).then(() => {
          proxy!.$modal.msgSuccess('新增成功')
          open.value = false
          getList()
        })
      }
    }
  })
}

function handleDelete(row: {{model_pascal}}) {
  const _{{pk_field}}s = row.{{pk_field}} ?? ids.value
  proxy!.$modal.confirm('是否确认删除{{function_name}}编号为"' + _{{pk_field}}s + '"的数据项？').then(() => {
    return del{{model_pascal}}(_{{pk_field}}s as number[])
  }).then(() => {
    getList()
    proxy!.$modal.msgSuccess('删除成功')
  }).catch(() => {})
}

function handleExport() {
  proxy!.download('{{module_name}}/{{model_camel}}/export', { ...queryParams.value }, `{{model_camel}}_${new Date().getTime()}.xlsx`)
}

getList()
</script>
